---
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../components/Logo.svelte";
import Footer from "../components/Footer.svelte";
---

<BaseLayout title="Live Coders Naarm">
    <main class="max-w-4xl mx-auto">
        <div class="">
            <Logo variant="large" client:load />
        </div>
        <div class="overflow-hidden text-primary py-2">
            <span class="border">
                ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
            </span>
        </div>
        <div class="px-4 min-h-[30vh]">
            <div class="px-4">
                <div>
                    <h1>Live Coders Naarm</h1>
                    <p>
                        Creative coding meetups for everyone in Melbourne,
                        Australia
                    </p>
                </div>

                <nav class="text-right">
                    <ul>
                        <li>
                            <a href="/discord"> join the discord </a>
                        </li>
                        <li>
                            <a href="/about"> about </a>
                        </li>

                        <li>
                            <a href="/tools"> tools </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </main>
    <div class="hidden sm:block">
        <div class="absolute -z-10">
            <Logo variant="blank" client:visible />
        </div>
        <div class="max-w-4xl mx-auto pt-12">
            <Footer />
        </div>
    </div>
</BaseLayout>

<style>
    a {
        color: var(--color-primary);
        text-decoration: underline;
    }
</style>
